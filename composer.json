{
  "name": "origamy/php-sdk",
  "description": "PHP SDK for the Origamy analytics API",
  "license": "MIT",
  "type": "library",
  "require": {
    "php": "^8.1",
    "ramsey/uuid": "^4.7"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "Origamy\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Origamy\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --no-coverage"
  },
  "config": {
    "sort-packages": true
  }
}
